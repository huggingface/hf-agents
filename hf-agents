#!/usr/bin/env bash
# hf-agents — bridge llmfit hardware detection and Pi coding agent via llama.cpp
set -euo pipefail

VERSION="0.2.1"
PORT="${LLAMA_SERVER_PORT:-8080}"
LLAMA_LOG="/tmp/hf-agents-llama-server.log"
PI_MODELS_DIR="$HOME/.pi/agent"
PI_MODELS_JSON="$PI_MODELS_DIR/models.json"
PI_MODELS_BACKUP="$PI_MODELS_JSON.hf-agents-bak"

# Track what we started so cleanup knows what to tear down
LLAMA_PID=""
STARTED_SERVER=false
MODIFIED_PI_CONFIG=false

cleanup() {
    # Restore Pi config
    if $MODIFIED_PI_CONFIG; then
        if [[ -f "$PI_MODELS_BACKUP" ]]; then
            mv "$PI_MODELS_BACKUP" "$PI_MODELS_JSON"
        else
            rm -f "$PI_MODELS_JSON"
        fi
    fi

    # Kill llama-server only if we started it
    if $STARTED_SERVER && [[ -n "$LLAMA_PID" ]]; then
        kill "$LLAMA_PID" 2>/dev/null || true
        wait "$LLAMA_PID" 2>/dev/null || true
    fi
}

die() { echo "Error: $*" >&2; exit 1; }

# Version comparison: returns 0 if $1 >= $2
version_gte() {
    local v1="$1" v2="$2"
    local IFS='.'
    local i ver1=($v1) ver2=($v2)
    for i in 0 1 2; do
        local n1="${ver1[$i]:-0}" n2="${ver2[$i]:-0}"
        [[ $n1 -gt $n2 ]] && return 0
        [[ $n1 -lt $n2 ]] && return 1
    done
    return 0
}

# Check for newer version (non-blocking, silent on failure)
check_update() {
    local latest
    latest="$(curl -sf --max-time 3 \
        "https://raw.githubusercontent.com/huggingface/hf-agents/main/manifest.json" \
        | jq -r '.version // empty' 2>/dev/null)" || return 0
    # Only show upgrade message if latest version is actually newer than current
    if [[ -n "$latest" ]] && ! version_gte "$VERSION" "$latest"; then
        echo -e "\033[33mA new version of hf-agents is available: $latest (current: $VERSION)\033[0m"
        echo -e "  Update with: \033[1mhf extensions install hf-agents --force\033[0m"
        echo ""
    fi
}

is_macos() { [[ "$(uname -s)" == "Darwin" ]]; }

# Ensure Homebrew is installed (macOS only)
ensure_brew() {
    command -v brew >/dev/null 2>&1 && return
    echo "Homebrew not found. Installing..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" \
        || die "Failed to install Homebrew."
    # Add brew to PATH for this session
    if [[ -x /opt/homebrew/bin/brew ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -x /usr/local/bin/brew ]]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
    command -v brew >/dev/null 2>&1 || die "Homebrew installed but 'brew' not found in PATH."
}

# Generate an install hint for a missing package (Linux)
linux_install_hint() {
    local pkg="$1"
    if command -v apt-get >/dev/null 2>&1; then
        echo "  sudo apt-get install $pkg"
    elif command -v dnf >/dev/null 2>&1; then
        echo "  sudo dnf install $pkg"
    elif command -v pacman >/dev/null 2>&1; then
        echo "  sudo pacman -S $pkg"
    elif command -v zypper >/dev/null 2>&1; then
        echo "  sudo zypper install $pkg"
    elif command -v apk >/dev/null 2>&1; then
        echo "  sudo apk add $pkg"
    else
        echo "  Install '$pkg' using your distribution's package manager."
    fi
}

# Ensure a dependency is available, installing it if missing
ensure_dep() {
    local cmd="$1"

    # llmfit: always update to latest version
    if [[ "$cmd" == "llmfit" ]]; then
        # Detect local install path first, even if extension PATH is minimal.
        if [[ -x "$HOME/.local/bin/llmfit" ]] && [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
            export PATH="$HOME/.local/bin:$PATH"
        fi
        if [[ -x "$HOME/.cargo/bin/llmfit" ]] && [[ ":$PATH:" != *":$HOME/.cargo/bin:"* ]]; then
            export PATH="$HOME/.cargo/bin:$PATH"
        fi
        if command -v llmfit >/dev/null 2>&1; then
            echo "Using existing llmfit: $(command -v llmfit)"
            return
        fi

        if is_macos; then
            ensure_brew
            if brew list llmfit &>/dev/null; then
                echo "Updating llmfit..."
                brew upgrade llmfit 2>/dev/null || true
            else
                echo "Installing llmfit..."
                brew install llmfit || die "Failed to install llmfit via Homebrew."
            fi
        else
            if command -v llmfit >/dev/null 2>&1; then
                echo "Updating llmfit..."
            else
                echo "Installing llmfit..."
            fi
            curl -fsSL https://llmfit.axjns.dev/install.sh | sh \
                || die "Failed to install/update llmfit."
        fi
        command -v llmfit >/dev/null 2>&1 || die "'llmfit' installed but not found in PATH."
        return
    fi

    command -v "$cmd" >/dev/null 2>&1 && return

    if is_macos; then
        case "$cmd" in
            curl)
                die "'curl' is required. Please install it: brew install curl" ;;
            jq|fzf)
                die "'$cmd' is required. Please install it: brew install $cmd" ;;
            llama-server)
                die "'llama-server' is required. Please install it: brew install llama.cpp" ;;
            npm)
                die "'npm' is required. Please install it: brew install node" ;;
            *)
                die "'$cmd' is required but not found in PATH." ;;
        esac
    else
        # Linux: don't auto-install system packages — tell the user what's needed
        case "$cmd" in
            curl)
                die "'curl' is required. Please install it:
$(linux_install_hint curl)" ;;
            jq|fzf)
                die "'$cmd' is required. Please install it:
$(linux_install_hint "$cmd")" ;;
            llama-server)
                die "'llama-server' is required. Please install llama.cpp:
  https://github.com/ggml-org/llama.cpp/blob/master/docs/install.md" ;;
            npm)
                die "'npm' is required. Please install Node.js:
$(linux_install_hint nodejs)" ;;
            *)
                die "'$cmd' is required but not found in PATH." ;;
        esac
    fi
    command -v "$cmd" >/dev/null 2>&1 || die "'$cmd' installed but not found in PATH."
}

# Ensure common tool paths are in PATH (hf extensions may not inherit full shell env)
ensure_path() {
    local dir
    for dir in /opt/homebrew/bin /usr/local/bin; do
        if [[ -d "$dir" ]] && [[ ":$PATH:" != *":$dir:"* ]]; then
            export PATH="$dir:$PATH"
        fi
    done
}

# Ensure Pi is installed and up-to-date
ensure_pi() {
    ensure_path
    if command -v pi >/dev/null 2>&1; then
        echo "Updating Pi..."
        pi update 2>/dev/null || echo "Pi update check done."
    else
        echo "Pi not found. Installing..."
        ensure_dep npm
        npm install -g @mariozechner/pi-coding-agent || die "Failed to install Pi."
        ensure_path
        command -v pi >/dev/null 2>&1 || die "Pi installed but 'pi' not found in PATH. Check your npm global bin directory."
        echo "Pi installed successfully."
    fi
}

# Format bytes to human-readable (e.g. 1073741824 → 1.0G)
human_bytes() {
    awk -v b="$1" 'BEGIN {
        if (b >= 1073741824) printf "%.1fG", b/1073741824
        else if (b >= 1048576) printf "%.0fM", b/1048576
        else if (b >= 1024)    printf "%.0fK", b/1024
        else                   printf "%dB", b
    }'
}

# Get file size in bytes (portable across macOS and Linux)
file_bytes() {
    wc -c < "$1" 2>/dev/null | tr -d ' '
}

usage() {
    cat <<EOF
hf-agents $VERSION — local coding agents powered by llmfit + llama.cpp

Usage:
  hf agents fit [args...]                    Hardware detection & model recommendations (llmfit passthrough)
  hf agents run pi [model] [--top N] [args...]  Start llama-server and launch Pi coding agent
  hf agents --help                           Show this help
  hf agents --version                        Show version

Environment:
  LLAMA_SERVER_PORT      Port for llama-server (default: 8080)
  LLAMA_SERVER_TIMEOUT   Startup timeout in seconds (default: 600)
  HF_TOKEN               Hugging Face token for gated model downloads

Examples:
  hf agents fit recommend -n 5       # top 5 models for your hardware
  hf agents fit system               # show detected hardware
  hf agents run pi                                        # auto-pick best model for your hardware
  hf agents run pi --top 5                                # pick from top 5 recommended models
  hf agents run pi unsloth/Qwen3-Coder-Next-GGUF:q4_k_m   # specify a model directly
  hf agents run pi --print "hello"                         # non-interactive mode
EOF
}

# ── Subcommand: fit (llmfit passthrough) ─────────────────────────────────────

cmd_fit() {
    ensure_dep llmfit
    exec llmfit "$@"
}

# ── Subcommand: run pi ──────────────────────────────────────────────────────

cmd_run_pi() {
    # Parse optional model ID and --top N flag
    local hf_repo=""
    local top_n=0
    local pi_args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --top)
                [[ $# -ge 2 ]] || die "--top requires a number argument"
                top_n="$2"
                [[ "$top_n" =~ ^[1-9][0-9]*$ ]] || die "--top must be a positive integer"
                shift 2
                ;;
            -*)
                pi_args+=("$1")
                shift
                ;;
            *)
                if [[ -z "$hf_repo" ]]; then
                    hf_repo="$1"
                else
                    pi_args+=("$1")
                fi
                shift
                ;;
        esac
    done

    # Step 1: Ensure dependencies — curl first, skip fzf/llmfit if model specified
    local deps=(curl jq llama-server npm)
    if [[ -z "$hf_repo" ]]; then
        deps+=(llmfit)
        if [[ "$top_n" -gt 0 ]]; then
            deps+=(fzf)
        fi
    fi
    for cmd in "${deps[@]}"; do
        ensure_dep "$cmd"
    done

    # Install or update Pi
    ensure_pi

    # Step 2: Check if llama-server is already running on the port
    if curl -sf "http://localhost:$PORT/health" >/dev/null 2>&1; then
        echo "Using existing llama-server on port $PORT."
    elif lsof -i :"$PORT" -sTCP:LISTEN >/dev/null 2>&1; then
        die "Port $PORT is in use but not responding to health checks. Kill the existing process or use LLAMA_SERVER_PORT=<port>."
    else
        # Step 3 & 4: Get model — either from arg or interactive selection
        local model_ctx=""
        if [[ -z "$hf_repo" ]]; then
            echo "Detecting hardware and fetching model recommendations..."
            local recommend_json
            local fetch_n=$(( top_n > 30 ? top_n * 4 : 100 ))
            recommend_json="$(llmfit recommend --json --use-case coding --force-runtime llamacpp -n "$fetch_n")" \
                || die "llmfit recommend failed."

            # Filter to models with GGUF sources and deduplicate by model name (keep highest score)
            local models_all
            models_all="$(echo "$recommend_json" | jq '
                [.models[] | select(.gguf_sources | length > 0)]
                | group_by(.name | split("/")[1])
                | map(sort_by(-.score)[0])
                | sort_by(-.score)
            ')"

            if [[ "$top_n" -eq 0 ]]; then
                # Auto-pick: take the first GGUF-compatible model
                local best
                best="$(echo "$models_all" | jq '.[0] //empty')"
                [[ -n "$best" ]] || die "No GGUF-compatible models found for your hardware."

                hf_repo="$(echo "$best" | jq -r '"\(.gguf_sources[0].repo):\(.best_quant)"')"
                model_ctx="$(echo "$best" | jq -r '.context_length // empty')"
                local model_name model_score
                model_name="$(echo "$best" | jq -r '.name')"
                model_score="$(echo "$best" | jq -r '.score')"
                echo "Selected: $model_name (score: $model_score)"
                echo "  → $hf_repo"
            else
                # Interactive: show top N in fzf picker
                local top_models
                top_models="$(echo "$models_all" | jq --argjson n "$top_n" '.[:$n]')"

                local count
                count="$(echo "$top_models" | jq 'length')"
                [[ "$count" -gt 0 ]] || die "No GGUF-compatible models found for your hardware."

                # Build lines: repo:quant \t name \t quant \t params \t tps \t score
                local fzf_input
                fzf_input="$(echo "$top_models" | jq -r '
                    .[] |
                    "\(.gguf_sources[0].repo):\(.best_quant)\t\(.name)\t\(.best_quant)\t\(.parameter_count)\t\(.estimated_tps) tok/s\tscore: \(.score)"
                ' | awk -F'\t' '{
                    printf "%s\t%-50s  %-10s  %-12s  %-12s  %s\n", $1, $2, $3, $4, $5, $6
                }')"

                # Detect clipboard command for ctrl-y copy
                local clip_cmd=""
                if is_macos; then
                    clip_cmd="pbcopy"
                elif command -v xclip >/dev/null 2>&1; then
                    clip_cmd="xclip -selection clipboard"
                elif command -v xsel >/dev/null 2>&1; then
                    clip_cmd="xsel --clipboard"
                elif command -v wl-copy >/dev/null 2>&1; then
                    clip_cmd="wl-copy"
                fi

                local fzf_header
                fzf_header="$(printf '%-50s  %-10s  %-12s  %-12s  %s' 'Name' 'Quant' 'Params' 'Speed' 'Score')"
                local fzf_bind_args=()
                if [[ -n "$clip_cmd" ]]; then
                    fzf_header+=$'\n  space: copy model ID to clipboard'
                    fzf_bind_args=(--bind "space:execute-silent(echo -n {1} | $clip_cmd)+change-header:Copied! Press enter to select.")
                fi

                local selection
                selection="$(echo "$fzf_input" | fzf \
                    --prompt="Model: " \
                    --height=50% \
                    --reverse \
                    --delimiter=$'\t' \
                    --with-nth=2.. \
                    --header="$fzf_header" \
                    "${fzf_bind_args[@]}")" \
                    || die "No model selected."

                hf_repo="$(echo "$selection" | cut -f1)"
                local model_name model_score
                model_name="$(echo "$selection" | awk -F'\t' '{print $2}' | xargs)"
                model_score="$(echo "$selection" | awk -F'\t' '{print $6}' | xargs)"
                echo "Selected: $model_name ($model_score)"
                echo "  → $hf_repo"

                # Look up context_length from the selected model
                local selected_repo
                selected_repo="$(echo "$hf_repo" | cut -d: -f1)"
                model_ctx="$(echo "$top_models" | jq -r --arg repo "$selected_repo" \
                    '[.[] | select(.gguf_sources[0].repo == $repo)][0].context_length // empty')"
            fi
        else
            echo "Using model: $hf_repo"
        fi

        # Step 5: Start llama-server in background
        trap cleanup EXIT INT TERM
        STARTED_SERVER=true

        echo "Starting llama-server on port $PORT..."
        llama-server -hf "$hf_repo" --jinja --port "$PORT" > "$LLAMA_LOG" 2>&1 &
        LLAMA_PID=$!

        # Health-check loop with progress indicator
        local timeout="${LLAMA_SERVER_TIMEOUT:-600}"
        local elapsed=0
        local spinner=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
        local spin_i=0
        local status_msg="starting"
        local dl_file=""
        local dl_total_bytes=""
        local dl_total_human=""

        while [[ $elapsed -lt $timeout ]]; do
            # Check if process is still alive
            if ! kill -0 "$LLAMA_PID" 2>/dev/null; then
                printf "\r\033[K" >&2
                echo "llama-server exited unexpectedly. Last 20 lines of log:" >&2
                tail -20 "$LLAMA_LOG" >&2
                exit 1
            fi

            if curl -sf "http://localhost:$PORT/health" >/dev/null 2>&1; then
                printf "\r\033[K"
                echo "llama-server is ready."
                break
            fi

            # Detect what llama-server is doing from the log
            # Run in a subshell to prevent grep failures from tripping set -e
            status_msg="$(
                set +e
                log="$LLAMA_LOG"
                if grep -q "warming up" "$log" 2>/dev/null; then
                    echo "warming up"
                elif grep -q "load_tensors:" "$log" 2>/dev/null; then
                    offload="$(grep -o 'offloaded [0-9]*/[0-9]* layers' "$log" 2>/dev/null | tail -1)"
                    if [[ -n "$offload" ]]; then
                        echo "loading model ($offload)"
                    else
                        echo "loading model tensors"
                    fi
                elif grep -q "loading model\|srv.*load_model" "$log" 2>/dev/null; then
                    echo "loading model"
                elif grep -q "downloadInProgress" "$log" 2>/dev/null; then
                    echo "downloading"
                else
                    echo ""
                fi
            )" || true

            # Handle download progress separately (needs to update outer variables)
            if [[ "$status_msg" == "downloading" ]] || { [[ "$status_msg" == "starting" ]] && grep -q "downloadInProgress" "$LLAMA_LOG" 2>/dev/null; }; then
                # Get download file path (once)
                if [[ -z "$dl_file" ]]; then
                    dl_file="$(grep -o '/[^ ]*\.downloadInProgress' "$LLAMA_LOG" 2>/dev/null | tail -1 || true)"
                    # Get total size via HEAD on the download URL (once)
                    local dl_url
                    dl_url="$(grep -o 'https://[^ ]*\.gguf' "$LLAMA_LOG" 2>/dev/null | tail -1 || true)"
                    if [[ -n "$dl_url" ]]; then
                        local head_args=(-sfLI)
                        local hf_token="${HF_TOKEN:-$(hf auth token 2>/dev/null || true)}"
                        if [[ -n "$hf_token" ]]; then
                            head_args+=(-H "Authorization: Bearer $hf_token")
                        fi
                        local content_length
                        content_length="$(curl "${head_args[@]}" "$dl_url" 2>/dev/null \
                            | grep -i content-length | tail -1 | awk '{print $2}' | tr -d '\r' || true)"
                        if [[ -n "$content_length" ]] && [[ "$content_length" -gt 0 ]] 2>/dev/null; then
                            dl_total_bytes="$content_length"
                            dl_total_human="$(human_bytes "$dl_total_bytes")"
                        fi
                    fi
                fi
                # Show current / total
                if [[ -n "$dl_file" ]] && [[ -f "$dl_file" ]]; then
                    local dl_cur_bytes
                    dl_cur_bytes="$(file_bytes "$dl_file" || echo 0)"
                    local dl_cur_human
                    dl_cur_human="$(human_bytes "$dl_cur_bytes")"
                    if [[ -n "$dl_total_human" ]]; then
                        local pct=$((dl_cur_bytes * 100 / dl_total_bytes))
                        status_msg="downloading model ${dl_cur_human}/${dl_total_human} (${pct}%)"
                    else
                        status_msg="downloading model (${dl_cur_human})"
                    fi
                else
                    status_msg="downloading model"
                fi
            fi

            # Keep previous status if detection returned empty
            [[ -z "$status_msg" ]] && status_msg="starting"

            local mins=$((elapsed / 60))
            local secs=$((elapsed % 60))
            local time_str
            if [[ $mins -gt 0 ]]; then
                time_str="${mins}m${secs}s"
            else
                time_str="${secs}s"
            fi

            printf "\r\033[K  %s %s (%s)" "${spinner[$spin_i]}" "$status_msg" "$time_str"
            spin_i=$(( (spin_i + 1) % ${#spinner[@]} ))

            # Read keypress with timeout (detect Esc to cancel)
            local key=""
            read -rsn1 -t 2 key || true
            if [[ "$key" == $'\x1b' ]]; then
                printf "\r\033[K"
                echo "Cancelled."
                exit 1
            fi
            elapsed=$((elapsed + 2))
        done

        if [[ $elapsed -ge $timeout ]]; then
            printf "\r\033[K"
            die "llama-server failed to start within $((timeout / 60))m. Check $LLAMA_LOG"
        fi
    fi

    # Step 6: Configure Pi
    # Register cleanup trap (might already be set if we started the server)
    if ! $STARTED_SERVER; then
        trap cleanup EXIT INT TERM
    fi
    MODIFIED_PI_CONFIG=true

    mkdir -p "$PI_MODELS_DIR"

    # Back up existing models.json (only if backup doesn't already exist)
    if [[ -f "$PI_MODELS_JSON" ]] && [[ ! -f "$PI_MODELS_BACKUP" ]]; then
        cp "$PI_MODELS_JSON" "$PI_MODELS_BACKUP"
    fi

    # Get the model ID from the running server
    local model_id
    model_id="$(curl -sf "http://localhost:$PORT/v1/models" \
        | jq -r '.data[0].id // empty')" || true

    if [[ -z "$model_id" ]]; then
        model_id="local-model"
    fi

    # Build model entry — include contextWindow only if available from llmfit
    local model_entry
    if [[ -n "$model_ctx" ]]; then
        model_entry="$(jq -n --arg id "$model_id" --argjson ctx "$model_ctx" \
            '{ id: $id, contextWindow: $ctx }')"
    else
        model_entry="$(jq -n --arg id "$model_id" '{ id: $id }')"
    fi

    cat > "$PI_MODELS_JSON" <<PIEOF
{
  "providers": {
    "llama-cpp": {
      "baseUrl": "http://localhost:$PORT/v1",
      "api": "openai-completions",
      "apiKey": "none",
      "models": [
        $model_entry
      ]
    }
  }
}
PIEOF

    echo "Pi configured to use local llama-server (model: $model_id)."

    # Step 7: Launch Pi
    pi --provider llama-cpp --model "$model_id" "${pi_args[@]+"${pi_args[@]}"}"
}

# ── Main routing ─────────────────────────────────────────────────────────────

check_update

case "${1:-}" in
    fit)
        shift
        cmd_fit "$@"
        ;;
    run)
        shift
        case "${1:-}" in
            pi)
                shift
                cmd_run_pi "$@"
                ;;
            *)
                die "Unknown target: '${1:-}'. Currently supported: hf-agents run pi"
                ;;
        esac
        ;;
    --help|-h)
        usage
        ;;
    --version|-v)
        echo "hf-agents $VERSION"
        ;;
    *)
        usage
        exit 1
        ;;
esac